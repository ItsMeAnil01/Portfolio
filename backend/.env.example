# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (AWS RDS PostgreSQL connection string in production)
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin bootstrap (used only by seed script to create your first admin login)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_me_now

# Mail (contact form). Works with Gmail app password, SendGrid SMTP, or AWS SES SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
CONTACT_RECEIVER_EMAIL=you@example.com
